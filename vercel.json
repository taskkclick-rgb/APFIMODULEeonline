{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    },
    "*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.php?path=$1" },
    { "src": "/module/(.*)", "dest": "/module.php?id=$1" },
    { "src": "/", "dest": "/index.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
